{
  "entities": {
    "MenuItem": {
      "title": "MenuItem",
      "description": "A single dish in the restaurant menu.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "ingredients": {
          "type": "array",
          "items": { "type": "string" }
        },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "price", "category", "description", "image"]
    }
  },
  "firestore": {
    "menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "The collection of all menu items."
    }
  }
}
